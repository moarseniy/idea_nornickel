APP_NAME=Hypothesis Lab
LOG_LEVEL=INFO
UVICORN_LOG_LEVEL=info

# Нужен для генерации гипотез и чата.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
# Не заполняйте для обычного OpenAI API. Если задаете совместимый endpoint, укажите URL с http:// или https://.
OPENAI_BASE_URL=
OPENAI_GRAPH_EXTRACTION=true
# Если пусто, используется OPENAI_MODEL. Research вызывает hosted web_search tool Responses API.
OPENAI_RESEARCH_MODEL=
OPENAI_RESEARCH_MAX_SOURCES=8
OPENAI_VISION_DETAIL=high

MAX_DOCUMENT_CHARS=120000
MAX_CONTEXT_CHARS=28000
MAX_UPLOAD_BYTES=36700160

# Парсинг PDF:
# 1) editable text-layer -> обычное извлечение текста;
# 2) image-page with OCR text -> EasyOCR;
# 3) image-page without OCR text -> OpenAI vision, ограничено PDF_VISION_MAX_PAGES.
PDF_OCR_ENABLED=true
# EasyOCR language codes. Default covers Russian, English and Simplified Chinese.
PDF_OCR_LANGUAGES=ru,en,ch_sim
PDF_OCR_MIN_CHARS=12
PDF_TEXT_LAYER_MIN_CHARS=16
PDF_RENDER_DPI=160
PDF_VISION_MAX_PAGES=200
